{
	"name": "bav4",
	"dependencies": {
		"@geoblocks/ol-maplibre-layer": "1.0.3",
		"chart.js": "4.5.1",
		"dompurify": "3.4.11",
		"geographiclib-geodesic": "2.2.0",
		"lit-html": "3.3.3",
		"maplibre-gl": "5.24.0",
		"ol": "10.9.0",
		"proj4": "2.20.9",
		"redux": "5.0.1",
		"vanilla-swipe": "2.4.1"
	},
	"devDependencies": {
		"@eslint/js": "9.39.2",
		"@jsdevtools/coverage-istanbul-loader": "3.0.5",
		"@playwright/test": "1.60.0",
		"@stylistic/eslint-plugin": "5.10.0",
		"@vitest/browser-playwright": "4.1.10",
		"@vitest/coverage-istanbul": "4.1.10",
		"bundlesize2": "0.0.35",
		"copy-webpack-plugin": "14.0.0",
		"css-loader": "7.1.4",
		"dependency-cruiser": "18.0.0",
		"docdash": "2.0.2",
		"dotenv-webpack": "9.0.0",
		"es-check": "9.6.4",
		"eslint": "9.39.2",
		"eslint-import-resolver-custom-alias": "1.3.2",
		"eslint-plugin-import": "2.32.0",
		"eslint-plugin-promise": "7.3.0",
		"gh-pages": "6.3.0",
		"globals": "17.7.0",
		"html-webpack-plugin": "5.6.7",
		"jsdoc": "4.0.5",
		"jsdoc-ts-utils": "6.0.0",
		"mapbox-gl-supported": "1.2.0",
		"mock-socket": "9.3.1",
		"portfinder-sync": "0.0.2",
		"prettier": "3.9.5",
		"style-loader": "4.0.0",
		"stylelint": "17.0.0",
		"stylelint-config-recommended": "18.0.0",
		"to-string-loader": "1.2.0",
		"vitest": "4.1.10",
		"webpack": "5.108.4",
		"webpack-bundle-analyzer": "5.3.0",
		"webpack-cli": "7.2.1",
		"webpack-dev-server": "6.0.0"
	},
	"scripts": {
		"start": "webpack serve --open --mode=development --devtool=inline-source-map",
		"start:nohostcheck": "webpack serve --open --mode=development --allowed-hosts all --host 0.0.0.0",
		"start:nohashing": "env HASH_FILENAMES=false webpack serve --open --mode=development --devtool=inline-source-map --env =false",
		"build:dev": "webpack --mode=development --devtool=inline-source-map",
		"build:prod": "webpack --mode=production --performance-hints=false",
		"doc": "jsdoc -c jsdoc.conf.json",
		"doc:apply": "node checkOrApplyDoc.js",
		"doc:check": "env DOC_CHECK=true node checkOrApplyDoc.js",
		"doc:wc": "npx -y web-component-analyzer src/modules/wc --format markdown --outDir documentation/wc; npx -y web-component-analyzer src/modules/wc --format json --outDir documentation/wc",
		"doc:deps": "npx depcruise src --include-only ^${npm_config_dir} --output-type dot | dot -T svg > dependency-graph.svg",
		"prettier:check": "prettier --check .",
		"prettier": "prettier --write .",
		"lint": "eslint --fix \"src/**/*.js\" \"test/**/*.js\" && npx stylelint --fix \"src/**/*.css\" && npx stylelint \"src/**/*.css\"",
		"test": "env VITEST_BROWSERS=${npm_config_browsers} npx vitest",
		"test:single": "rm -f console.log && env TEST_SINGLE_FILE=true env VITEST_BROWSERS=${npm_config_browsers:-chromium} npx vitest ${npm_config_test:-undefined}",
		"e2e": "npx playwright install; env URL=$npm_config_url npx playwright test --browser=${npm_config_browser:-all} --retries=3",
		"es-check": "es-check es2024 \"./src/**/*.js\" --module",
		"bundlesize": "npm run build:prod && npx bundlesize2",
		"analyze-bundle": "webpack --stats=detailed --json > stats.json && webpack-bundle-analyzer ./stats.json",
		"analyze-bundle-resources": "node analyzeBundleResources.js --input './src' --exclude 'src/assets/favicon'",
		"analyze-bundle-resources:detail": "node analyzeBundleResources.js --input './src' --exclude 'src/assets/favicon' --detail $npm_config_name",
		"optimize-svg": "npx svgo -r -f src/ --config svgo.config.js --final-newline --multipass",
		"gh-pages": "rm -rf node_modules/.cache/gh-pages && rm -rf dist && npm run build:prod && NODE_DEBUG=gh-pages gh-pages -d dist"
	}
}
